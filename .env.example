# ============================================================
# 에스테틱 법률 챗봇 (마젤원향) 환경 변수
# 이 파일을 복사하여 .env 로 저장 후 실제 값 입력
# cp .env.example .env
# ============================================================

# 법제처 OpenAPI 키 (https://open.law.go.kr)
LAW_API_KEY=여기에_법제처_OC키_입력

# 공공데이터포털 API 키 (https://www.data.go.kr)
PUBLIC_DATA_API_KEY=여기에_식약처_serviceKey_입력

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mazel_esthetic_db
DB_USER=mazel_user
DB_PASSWORD=mazel2026!

# OpenSearch
OS_HOST=https://localhost:9200
OS_USER=admin
OS_PASSWORD=Secure#Open2024!

# Ollama
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=bge-m3
LLM_MODEL=gemma4:e4b

# Redis (질문-답변 시맨틱 캐시)
